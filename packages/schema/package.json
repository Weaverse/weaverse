{
  "name": "@weaverse/schema",
  "version": "0.12.0",
  "description": "Schema definitions for Weaverse",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/types/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "manifest": [
        "dist/types/manifest.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && node ../../scripts/build-declarations.mjs",
    "clean": "rimraf dist",
    "test": "vp test --run",
    "typecheck": "tsc --noEmit"
  },
  "tsup": {
    "entry": [
      "src/index.ts",
      "src/manifest.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "sourcemap": true,
    "clean": true,
    "outDir": "dist"
  },
  "author": "Weaverse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weaverse/weaverse.git"
  },
  "publishConfig": {
    "access": "public",
    "@weaverse:registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
