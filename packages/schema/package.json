{
  "name": "@weaverse/schema",
  "version": "0.10.0",
  "description": "Schema definitions for Weaverse",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "clean": "rimraf dist",
    "test": "vp test --run"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "sourcemap": true,
    "clean": true,
    "outDir": "dist"
  },
  "author": "Weaverse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weaverse/weaverse.git"
  },
  "publishConfig": {
    "access": "public",
    "@weaverse:registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
