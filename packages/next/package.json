{
  "name": "@weaverse/next",
  "author": "Weaverse Team",
  "description": "Next.js App Router integration for building Weaverse-powered storefronts",
  "version": "0.1.0-alpha.12",
  "license": "MIT",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "@weaverse:registry": "https://registry.npmjs.org"
  },
  "repository": {
    "url": "git+https://github.com/Weaverse/weaverse.git",
    "directory": "packages/next"
  },
  "files": [
    "dist/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "clean": "rimraf dist",
    "test": "vp test --run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "tsup": {
    "entry": [
      "src/index.ts",
      "src/server.ts"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true,
    "sourcemap": true,
    "clean": true,
    "outDir": "dist",
    "treeshake": true,
    "external": [
      "next",
      "next/navigation"
    ]
  },
  "dependencies": {
    "@weaverse/react": "5.16.4",
    "@weaverse/schema": "0.10.0"
  },
  "devDependencies": {
    "next": "16.2.9"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=19",
    "react-dom": ">=19"
  }
}
