{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["scripts/build-declarations.mjs"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "outputs": [],
      "inputs": ["packages/**/*.ts", "packages/**/*.tsx"]
    }
  }
}
